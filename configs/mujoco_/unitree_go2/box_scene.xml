<mujoco model="go2 scene">
  <include file="go2_posctrl.xml"/>
  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.58 0.55" ambient="0.25 0.25 0.25" specular="0.3 0.3 0.3"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.4 0.6 0.8" rgb2="0.05 0.08 0.15"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.3 0.35 0.4" rgb2="0.18 0.22 0.28"
             markrgb="0.9 0.9 0.9" width="300" height="300"/>
    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.35"/>
  </asset>

  <worldbody>
      <camera name="fixed_cam" pos="2.774 -3.206 3.059" xyaxes="0.756 0.654 -0.000 -0.383 0.442 0.811"/>

    <light name="key_light"
           pos="-2 -3 4" dir="0.4 0.6 -0.7"
           diffuse="1.0 0.95 0.85" specular="0.4 0.38 0.32"
           ambient="0.0 0.0 0.0"
           castshadow="true" directional="true"/>

    <light name="fill_light"
           pos="3 2 3" dir="-0.5 -0.4 -0.6"
           diffuse="0.35 0.4 0.5" specular="0.05 0.05 0.08"
           ambient="0.0 0.0 0.0"
           castshadow="false" directional="true"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <body name="obj" pos="1.0 0.0 0.3">
      <freejoint />

      <!-- Collision + mass go here -->
      <geom name="obj_col"
            type="box"
            size="0.1 0.1 0.1"
            rgba="0 0 0 0"
            mass="0.2"/>

      <!-- Visual faces only (no mass, no collisions) -->

      <!-- +X face -->
      <geom type="box" pos="0.0998 0 0"
            size="0.001 0.1 0.1"
            rgba="1 0 0 1"
            contype="0" conaffinity="0" density="0"/>

      <!-- -X face -->
      <geom type="box" pos="-0.0998 0 0"
            size="0.001 0.1 0.1"
            rgba="0 1 0 1"
            contype="0" conaffinity="0" density="0"/>

      <!-- +Y face -->
      <geom type="box" pos="0 0.0998 0"
            size="0.1 0.001 0.1"
            rgba="0 0 1 1"
            contype="0" conaffinity="0" density="0"/>

      <!-- -Y face -->
      <geom type="box" pos="0 -0.0998 0"
            size="0.1 0.001 0.1"
            rgba="1 1 0 1"
            contype="0" conaffinity="0" density="0"/>

      <!-- +Z face -->
      <geom type="box" pos="0 0 0.0998"
            size="0.1 0.1 0.001"
            rgba="1 0 1 1"
            contype="0" conaffinity="0" density="0"/>

      <!-- -Z face -->
      <geom type="box" pos="0 0 -0.0998"
            size="0.1 0.1 0.001"
            rgba="0 1 1 1"
            contype="0" conaffinity="0" density="0"/>

      <!-- Box markers -->
      <geom name="box_marker_0" type="sphere" pos="-0.0998 0.1 0.1"
            size="0.01"
            rgba="1 0 0 0.5"
            contype="0" conaffinity="0" density="0"/>
      
      <geom name="box_marker_1" type="sphere" pos="0.1 -0.0998 0.1"
            size="0.01"
            rgba="1 0 0 0.5"
            contype="0" conaffinity="0" density="0"/>
      
      <geom name="box_marker_2" type="sphere" pos="0.1 0.1 -0.0998"
            size="0.01"
            rgba="1 0 0 0.5"
            contype="0" conaffinity="0" density="0"/>
    </body>
  </worldbody>
</mujoco>
